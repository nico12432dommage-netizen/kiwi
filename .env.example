# Plantilla de Configuración Técnica
# Copa este archivo como .env y cambia los valores

# Clave secreta de Django (Usa una frase larga y aleatoria en producción)
SECRET_KEY=cambiar-esto-por-una-clave-muy-larga-y-segura-12345

# Base de Datos (Solo necesario si usas PostgreSQL en Render)
# Ejemplo: postgres://usuario:password@host:puerto/nombre_db
DATABASE_URL=

# En Render, la variable RENDER=true ya viene configurada por defecto
